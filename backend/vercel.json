{
  "version": 2,
  "name": "qr-obuchai",
  "builds": [
    {
      "src": "backend/main.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.14"
      }
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "frontend/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "PYTHONPATH": "backend"
  },
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "0 18 * * *",
      "timezone": "Europe/Moscow"
    },
    {
      "path": "/api/cron/monthly-archive",
      "schedule": "0 2 1 * *",
      "timezone": "Europe/Moscow"
    }
  ]
}